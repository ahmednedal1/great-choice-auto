# Supabase — public values, safe for the browser (anon/public key only)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Shop contact info
# WhatsApp number: digits only, with country code, no + or spaces.
# Owner's number (226) 505-9118 -> 12265059118
NEXT_PUBLIC_WHATSAPP_NUMBER=12265059118
NEXT_PUBLIC_SHOP_NAME="Great Choice Auto Sales"

# --- Inquiry emails (server-only, never prefixed with NEXT_PUBLIC_) ---
# Emails are sent through Resend (https://resend.com). Create a free account,
# add an API key, and (recommended) verify your sending domain.
# If RESEND_API_KEY is left blank, inquiries still save to the dashboard —
# they just won't be emailed.
RESEND_API_KEY=
# Where inquiry notifications are sent. Defaults to the shop email if unset.
ADMIN_EMAIL=Greatchoiceautosales.inc@gmail.com
# Verified "from" address in Resend. Until you verify a domain you can use
# onboarding@resend.dev (Resend's shared test sender).
INQUIRY_FROM_EMAIL=onboarding@resend.dev
